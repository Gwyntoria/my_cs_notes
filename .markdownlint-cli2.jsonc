{
  "globs": [
    "**/*.md",
    "#node_modules"
  ],
  "gitignore": ".gitignore",
  "config": {
    "line-length": false,
    "no-duplicate-heading": {
      "siblings_only": true
    },
    "no-inline-html": false,
    "no-emphasis-as-heading": true,
    "emphasis-style": {
      "style": "asterisk"
    },
    "strong-style": {
      "style": "asterisk"
    }
  }
}