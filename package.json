  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Gwyntoria/my_cs_notes/issues"
  },
  "homepage": "https://github.com/Gwyntoria/my_cs_notes#readme",
  "devDependencies": {
    "markdownlint-cli2": "^0.18.1",
    "textlint": "^15.5.4",
    "textlint-rule-ja-space-between-half-and-full-width": "^2.4.2",
    "textlint-rule-no-todo": "^2.0.1",
    "textlint-rule-prh": "^6.1.0",
    "textlint-rule-zh-half-and-full-width-bracket": "^1.1.0"
  }
